# ============================================================
#  OrcaCompute – Environment Configuration
#
#  Copy to .env and fill in values before running docker compose.
#  Never commit .env — it is in .gitignore.
#
#  Usage:
#    cp .env.example .env
#    docker compose --profile dev up -d
# ============================================================

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=orcastack
POSTGRES_USER=orcastack_user
POSTGRES_PASSWORD=XB2fcetmo5rV53LgPzQ07NDQlFG57QBqQCFNQd5hzdE=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for caching and Django Channels layer (production)
REDIS_URL=redis://redis:6379/0

# ── Django Backend ────────────────────────────────────────────────────────────
# Generate a real secret key for production:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=MOVrc6WdlfmO+Kuev1soPXr+8peVrEPNgpkKawjk+hyI7F79I6Bh3KSmFLRngXvG

# "True" for development, "False" for production
DEBUG=False

# Comma-separated list of allowed hostnames (no spaces)
ALLOWED_HOSTS=orcastack.org,api.orcastack.org,www.orcastack.org,localhost,127.0.0.1

# Full DATABASE_URL used by the backend container in prod
DATABASE_URL=postgresql://orcastack_user:XB2fcetmo5rV53LgPzQ07NDQlFG57QBqQCFNQd5hzdE=@db:5432/orcacompute

# CORS — comma-separated origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://orcastack.org,https://www.orcastack.org,https://api.orcastack.org

# ── Message Broker ────────────────────────────────────────────────────────────
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=MOVrc6WdlfmO+Kuev1soPXr+8peVrEPNgpkKawjk+hyI7F79I6Bh3KSmFL
RABBITMQ_URL=amqp://admin:MOVrc6WdlfmO+Kuev1soPXr+8peVrEPNgpkKawjk+hyI7F79I6Bh3KSmFL@rabbitmq:5672/

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_ENABLED=true

# ── Monitoring ────────────────────────────────────────────────────────────────
PROMETHEUS_PUSHGATEWAY_URL=http://pushgateway:9091
GRAFANA_PASSWORD=admin123

# ── OpenStack (platform integration) ─────────────────────────────────────────
OS_CLOUD=orcastack
OS_AUTH_URL=http://172.27.112.36:5000/v3
OS_USERNAME=orcastack-svc
OS_PASSWORD=changeme
OS_PROJECT_NAME=orcastack
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_DOMAIN_NAME=Default

# ── Frontend (used by frontend container) ────────────────────────────────────
# Points the React app at the backend API
REACT_APP_API_URL=https://api.orcastack.org/api
REACT_APP_WS_URL=wss://api.orcastack.org/ws
REACT_APP_ENVIRONMENT=production
