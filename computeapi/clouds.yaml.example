# clouds.yaml – OpenStack client configuration
# Place this file at one of:
#   ~/.config/openstack/clouds.yaml      (user-level)
#   /etc/openstack/clouds.yaml           (system-wide)
#   ./clouds.yaml                        (current working directory)
#
# Reference: https://docs.openstack.org/python-openstackclient/latest/configuration/index.html
#
# Multiple cloud profiles can be defined. Use OS_CLOUD env var (or the
# openstack --os-cloud flag) to select one.

clouds:

  # Local DevStack or OpenStack All-in-One
  atonix:
    auth:
      auth_url: http://controller:5000/v3
      username: admin
      password: CHANGE_ME
      project_name: admin
      user_domain_name: Default
      project_domain_name: Default
    region_name: RegionOne
    interface: public
    identity_api_version: 3

  # Production OpenStack cluster
  atonix-prod:
    auth:
      auth_url: https://openstack.orcacompute.com:5000/v3
      username: api-user
      password: CHANGE_ME
      project_name: orcacompute-prod
      user_domain_name: Default
      project_domain_name: Default
    region_name: RegionOne
    interface: public
    identity_api_version: 3
    # Optional application credential alternative (preferred for CI/CD):
    # auth_type: v3applicationcredential
    # auth:
    #   auth_url: https://openstack.orcacompute.com:5000/v3
    #   application_credential_id: CREDENTIAL_ID
    #   application_credential_secret: CREDENTIAL_SECRET

  # ------------------------------------------------------------------------
  # OrcaCompute multi-region reference profiles
  # ------------------------------------------------------------------------
  # Region A = Public Cloud (multi-tenant)
  atonix-region-a-public:
    auth:
      auth_url: https://region-a.orcacompute.com:5000/v3
      username: api-public
      password: CHANGE_ME
      project_name: atonix-public-shared
      user_domain_name: Default
      project_domain_name: Default
    region_name: RegionA
    interface: public
    identity_api_version: 3

  # Region B = Private Cloud (dedicated enterprise projects)
  atonix-region-b-private:
    auth:
      auth_url: https://region-b.orcacompute.com:5000/v3
      username: api-private
      password: CHANGE_ME
      project_name: atonix-private-control
      user_domain_name: Default
      project_domain_name: Default
    region_name: RegionB
    interface: public
    identity_api_version: 3

  # Region C = Hybrid Cloud (connected to customer datacenters)
  atonix-region-c-hybrid:
    auth:
      auth_url: https://region-c.orcacompute.com:5000/v3
      username: api-hybrid
      password: CHANGE_ME
      project_name: atonix-hybrid-core
      user_domain_name: Default
      project_domain_name: Default
    region_name: RegionC
    interface: public
    identity_api_version: 3

  # Optional: service account profile that can be used with app credentials
  # in CI/CD jobs, then overridden per-request by WorkspaceBinding.
  atonix-service:
    auth_type: v3applicationcredential
    auth:
      auth_url: https://keystone.orcacompute.com:5000/v3
      application_credential_id: CHANGE_ME
      application_credential_secret: CHANGE_ME
    region_name: RegionA
    interface: public
    identity_api_version: 3

  # Microstack / MicroCloud
  microstack:
    auth:
      auth_url: http://10.20.20.1:5000/v3
      username: admin
      password: CHANGE_ME
      project_name: admin
      user_domain_name: Default
      project_domain_name: Default
    region_name: microstack
    interface: internalURL
    identity_api_version: 3
