# ==============================================
# DOMAIN AND NETWORKING
# ==============================================

# Primary domain for the application
domain_name = "orcacompute.org"

# TLS certificate secret name (leave empty for HTTP)
tls_secret_name = "orcacompute-tls"

# Ingress class to use
ingress_class = "nginx"

# CORS allowed origins
cors_allowed_origins = [
  "https://orcacompute.org",
  "https://www.orcacompute.org"
]

# Django allowed hosts
allowed_hosts = [
  "orcacompute.org",
  "www.orcacompute.org",
  "api.orcacompute.org"
]

# ==============================================
# CONTAINER IMAGES
# ==============================================

# Container registry settings
image_registry = "ghcr.io"

# Backend image configuration
backend_image_repository = "orcacompute/platform-backend"
backend_image_tag        = "latest"

# Frontend image configuration
